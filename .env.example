# Copy to .env.local and fill in your Supabase project values.
# Dashboard: https://supabase.com/dashboard → Project → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Setup:
# 1. Create a Supabase project
# 2. Run supabase/migrations/001_initial_schema.sql in SQL Editor
# 3. Auth → URL Configuration → add redirect: http://localhost:3000/auth/callback
# 4. (Optional) Disable email confirmation in Auth → Providers → Email for local dev
# 5. Restart `npm run dev` after updating this file
